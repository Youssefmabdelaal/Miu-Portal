{
  "info": {
    "name": "Smart University API",
    "description": "Postman collection for University Course Registration System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "courseId", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Student Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@university.edu\",\n  \"password\": \"Student123!\",\n  \"studentId\": \"S10012345\",\n  \"department\": \"cs\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/student/register"
          }
        },
        {
          "name": "Student Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"jane.doe@university.edu\",\n  \"password\": \"Student123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Admin Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin2@smartuniversity.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/admin/register"
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@smartuniversity.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "List Courses (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/courses?page=1&limit=12&search=CS"
          }
        },
        {
          "name": "Create Course (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Introduction to Computer Science\",\n  \"courseCode\": \"CS101\",\n  \"instructor\": \"Dr. Smith\",\n  \"schedule\": \"Mon/Wed 10:00-11:30\",\n  \"room\": \"Hall A-201\",\n  \"creditHours\": 3,\n  \"seats\": 30,\n  \"capacity\": 30,\n  \"description\": \"Fundamentals of programming\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/courses"
          }
        },
        {
          "name": "List Courses (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/courses"
          }
        },
        {
          "name": "Update Course (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Intro to CS (Updated)\",\n  \"seats\": 25\n}"
            },
            "url": "{{baseUrl}}/api/admin/courses/{{courseId}}"
          }
        },
        {
          "name": "Delete Course (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/courses/{{courseId}}"
          }
        }
      ]
    },
    {
      "name": "Enrollment",
      "item": [
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{courseId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/enrollments"
          }
        },
        {
          "name": "My Enrollments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/enrollments"
          }
        },
        {
          "name": "Drop Course",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/enrollments/{{courseId}}"
          }
        },
        {
          "name": "Admin View Enrollments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/enrollments"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Updated\"\n}"
            },
            "url": "{{baseUrl}}/api/profile"
          }
        },
        {
          "name": "Upload Profile Image",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "profileImage", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/profile/upload"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "External API Data",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/external"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    }
  ]
}
